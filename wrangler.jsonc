{
  "name": "madeleydesignstudio",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-07-04",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
