---
import Layout from "@/layouts/main.astro"
import PageHero from "@/components/universal/page-hero.astro"
import { getSiteSettings } from "@/lib/sanity/content"

const siteSettings = await getSiteSettings()
---

<Layout
  siteSettings={siteSettings}
  title="Company"
  description="Who we are at Madeley Design Studio — a design and software studio building for the AEC industry and beyond."
>
  <PageHero
    eyebrow="company"
    heading="Who we are."
    body="More on our company is coming soon."
  />
</Layout>
