---
import Layout from "@/layouts/main.astro"
import PageHero from "@/components/universal/page-hero.astro"
import { getSiteSettings } from "@/lib/sanity/content"

const siteSettings = await getSiteSettings()
---

<Layout
  siteSettings={siteSettings}
  title="Studio"
  description="Studio is Madeley Design Studio's design practice — brand, UI/UX, and marketing sites crafted with intention."
>
  <PageHero
    eyebrow="studio"
    heading="Design, crafted with intention."
    body="More on our studio work is coming soon."
  />
</Layout>
