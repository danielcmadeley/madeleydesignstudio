---
import Layout from "@/layouts/main.astro"
import PageHero from "@/components/universal/page-hero.astro"
import { getSiteSettings } from "@/lib/sanity/content"

const siteSettings = await getSiteSettings()
---

<Layout
  siteSettings={siteSettings}
  title="Forge"
  description="Forge is Madeley Design Studio's software practice — tailored systems and AI tools, built to last."
>
  <PageHero
    variant="dark"
    eyebrow="forge"
    heading="Software, built to last."
    body="More on our software work is coming soon."
  />
</Layout>
