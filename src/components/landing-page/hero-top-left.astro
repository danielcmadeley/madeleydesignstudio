---
interface HeroSlide {
  id: string
  headline: string
}

interface Props {
  slides: HeroSlide[]
}

const { slides } = Astro.props
---

<section
  data-hero-top-left
  class="relative col-span-2 row-start-1 min-h-0 px-8 py-10 md:px-12 md:py-14 will-change-transform"
>
  <div class="mb-6 flex items-center gap-1" data-hero-indicators aria-label="Hero slides">
    {
      slides.map((slide, index) => (
        <button
          type="button"
          data-hero-indicator={index}
          aria-label={`Show ${slide.id} slide`}
          aria-current={index === 0 ? "true" : "false"}
          class:list={[
            "h-3 border border-[#ff0000] transition-colors",
            index === 0 ? "w-8 bg-[#ff0000]" : "w-8 bg-transparent hover:bg-[#ff0000]/20",
          ]}
        />
      ))
    }
  </div>
  <div class="relative">
    {
      slides.map((slide, index) => (
        <h1
          data-hero-headline
          data-slide={index}
          class:list={[
            "font-heading max-w-2xl text-[clamp(1.75rem,3.5vw,3.25rem)] leading-[1.08] font-bold tracking-tight text-[#2a2a2a]",
            index === 0 ? "relative" : "absolute inset-0 opacity-0",
          ]}
        >
          {slide.headline}
        </h1>
      ))
    }
  </div>
</section>
