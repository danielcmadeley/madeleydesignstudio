---
interface HeroSlide {
  id: string
  headline: string
}

interface Props {
  slides: HeroSlide[]
}

const { slides } = Astro.props
---

<section
  data-hero-top-left
  class="relative col-span-2 row-start-1 flex min-h-0 flex-col px-8 py-10 md:px-12 md:py-14 will-change-transform"
>
  <div class="mt-auto flex flex-col gap-6">
    <div
      class="flex w-fit items-center justify-center gap-3 rounded-full border border-[#ff0000] px-5 py-2.5"
      data-hero-indicators
      aria-label="Hero slides"
    >
      {
        slides.map((slide, index) => (
          <button
            type="button"
            data-hero-indicator={index}
            aria-label={`Show ${slide.id} slide`}
            aria-current={index === 0 ? "true" : "false"}
            class="h-2.5 w-2.5 shrink-0 rounded-full bg-[#ff0000]/35 transition-all duration-300 aria-[current=true]:h-3 aria-[current=true]:w-8 aria-[current=true]:bg-[#ff0000] aria-[current=false]:hover:bg-[#ff0000]/50"
          />
        ))
      }
    </div>
    <div class="grid">
      {
        slides.map((slide, index) => (
          <h1
            data-hero-headline
            data-slide={index}
            class:list={[
              "col-start-1 row-start-1 font-heading max-w-2xl text-[clamp(1.75rem,3.5vw,3.25rem)] leading-[1.08] font-bold tracking-tight text-[#2a2a2a]",
              index === 0 ? "opacity-100" : "opacity-0",
            ]}
          >
            {slide.headline}
          </h1>
        ))
      }
    </div>
  </div>
</section>
