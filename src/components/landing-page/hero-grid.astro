---
import HeroTopLeft from "@/components/landing-page/hero-top-left.astro"
import HeroAecPanel from "@/components/landing-page/hero-aec-panel.astro"
import HeroBottomLeft from "@/components/landing-page/hero-bottom-left.astro"
import HeroBottomRight from "@/components/landing-page/hero-bottom-right.astro"
import HeroContinuation from "@/components/landing-page/hero-continuation.astro"
import PageSections from "@/components/landing-page/page-sections.astro"
import type {
  HeroSlideView,
  HomePageContent,
  SiteSettingsContent,
  VerticalSectionView,
} from "@/lib/sanity/types"

interface Props {
  heroSlides: HeroSlideView[]
  homePage: HomePageContent
  verticalSections: VerticalSectionView[]
  siteSettings: SiteSettingsContent
}

const { heroSlides, homePage, verticalSections, siteSettings } = Astro.props
---

<div class="mt-header">
  <main
    data-hero-main
    data-hero-slides={JSON.stringify(heroSlides)}
    data-hero-cycle-seconds={homePage.heroCycleSeconds}
    class="relative grid h-[calc(100svh-var(--spacing-header))] grid-cols-3 grid-rows-[3fr_2fr] items-stretch overflow-hidden"
  >
    <HeroTopLeft slides={heroSlides} />
    <HeroAecPanel slides={heroSlides} />
    <HeroBottomLeft />
    <HeroBottomRight />
  </main>
</div>

<HeroContinuation slides={heroSlides} tagline={homePage.continuationTagline} />

<PageSections
  verticalSections={verticalSections}
  services={homePage.services}
  footer={homePage.footer}
  siteSettings={siteSettings}
/>

<script>
  import gsap from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.registerPlugin(ScrollTrigger)

  type HeroSlide = {
    id: string
    headline: string
    subtext: string
    image: string
    flippedImage: string
  }

  let ctx: gsap.Context | undefined
  let cycleTimeline: gsap.core.Timeline | undefined
  let cycleDelay: gsap.core.Tween | undefined
  let activeSlide = 0
  let heroExpandProgress = 0
  let scrollTriggerInstance: ScrollTrigger | undefined
  let heroSlides: HeroSlide[] = []
  let heroCycleSeconds = 6
  let heroUiReady = false
  let applyHeroFrame: ((progress: number) => void) | undefined

  function getActiveLogo(panel: HTMLElement) {
    return panel.querySelector<HTMLImageElement>(
      `[data-hero-aec-logo][data-slide="${activeSlide}"]`
    )
  }

  function setIndicator(index: number) {
    document.querySelectorAll("[data-hero-indicator]").forEach((button, i) => {
      button.setAttribute("aria-current", i === index ? "true" : "false")
    })
  }

  function setSlideVisibility(slideElements: Element[], visibleIndex: number) {
    slideElements.forEach((element, index) => {
      gsap.set(element, { opacity: index === visibleIndex ? 1 : 0 })
    })
  }

  function updateVerticalSections(activeIndex: number) {
    document.querySelectorAll("[data-vertical-section]").forEach((section) => {
      const slide = Number(section.getAttribute("data-slide"))
      section.classList.toggle("hidden", slide !== activeIndex)
    })
  }

  function goToSlide(index: number) {
    const slideCount = heroSlides.length
    const nextIndex = ((index % slideCount) + slideCount) % slideCount
    if (nextIndex === activeSlide) return

    const prevIndex = activeSlide
    const headlines = gsap.utils.toArray<Element>("[data-hero-headline]")
    const subtexts = gsap.utils.toArray<Element>("[data-hero-subtext]")
    const continuations = gsap.utils.toArray<Element>(
      "[data-hero-continuation]"
    )
    const logos = gsap.utils.toArray<Element>("[data-hero-aec-logo]")

    cycleTimeline?.kill()

    gsap.set(
      [
        headlines[nextIndex],
        subtexts[nextIndex],
        continuations[nextIndex],
        logos[nextIndex],
      ],
      { opacity: 0 }
    )

    cycleTimeline = gsap.timeline({
      onComplete: () => {
        activeSlide = nextIndex
        setIndicator(nextIndex)
        setSlideVisibility(headlines, nextIndex)
        setSlideVisibility(subtexts, nextIndex)
        setSlideVisibility(continuations, nextIndex)
        setSlideVisibility(logos, nextIndex)
        updateVerticalSections(nextIndex)
        if (heroExpandProgress <= 0.001) {
          applyHeroFrame?.(0)
        }
      },
    })

    cycleTimeline.to(
      [
        headlines[prevIndex],
        subtexts[prevIndex],
        continuations[prevIndex],
        logos[prevIndex],
      ],
      { opacity: 0, duration: 0.6, ease: "power2.inOut" },
      0
    )

    cycleTimeline.to(
      [
        headlines[nextIndex],
        subtexts[nextIndex],
        continuations[nextIndex],
        logos[nextIndex],
      ],
      { opacity: 1, duration: 0.6, ease: "power2.inOut" },
      0
    )
  }

  function stopCycle() {
    cycleDelay?.kill()
  }

  function startCycle() {
    stopCycle()

    const scheduleNext = () => {
      cycleDelay = gsap.delayedCall(heroCycleSeconds, () => {
        if (heroExpandProgress <= 0.001) {
          goToSlide(activeSlide + 1)
        }
        scheduleNext()
      })
    }

    scheduleNext()
  }

  function initHeroCycle() {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches
    if (prefersReducedMotion) return

    heroSlides.forEach((slide) => {
      const img = new Image()
      img.src = slide.image
    })

    if (!heroUiReady) {
      heroUiReady = true
      document
        .querySelector("[data-hero-indicators]")
        ?.addEventListener("click", (event) => {
          const button = (event.target as Element | null)?.closest(
            "[data-hero-indicator]"
          )
          if (!button) return

          const index = Number(button.getAttribute("data-hero-indicator"))
          goToSlide(index)
          startCycle()
        })
    }

    startCycle()
  }

  function initHeroAecExpand() {
    ctx?.revert()
    scrollTriggerInstance = undefined

    const main = document.querySelector<HTMLElement>("[data-hero-main]")
    const panel = document.querySelector<HTMLElement>("[data-hero-aec]")
    const cell = document.querySelector<HTMLElement>("[data-hero-aec-cell]")
    const topLeft = document.querySelector<HTMLElement>("[data-hero-top-left]")
    const bottomLeft = document.querySelector<HTMLElement>(
      "[data-hero-bottom-left]"
    )
    const bottomRight = document.querySelector<HTMLElement>(
      "[data-hero-bottom-right]"
    )

    if (!main || !panel || !cell || !topLeft || !bottomLeft || !bottomRight)
      return

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches
    if (prefersReducedMotion) return

    const run = () => {
      const logo = getActiveLogo(panel)
      if (!logo) return

      ctx = gsap.context(() => {
        const getCellMetrics = () => {
          const mainRect = main.getBoundingClientRect()
          const cellRect = cell.getBoundingClientRect()

          return {
            top: cellRect.top - mainRect.top,
            left: cellRect.left - mainRect.left,
            width: cellRect.width,
            height: cellRect.height,
          }
        }

        main.appendChild(panel)

        const metrics = getCellMetrics()
        const bottomRowTop =
          bottomLeft.getBoundingClientRect().top -
          main.getBoundingClientRect().top

        const getLogoAspect = (activeLogo: HTMLImageElement) =>
          activeLogo.naturalWidth > 0
            ? activeLogo.naturalWidth / activeLogo.naturalHeight
            : activeLogo.offsetWidth / activeLogo.offsetHeight

        const logoEnd = (activeLogo: HTMLImageElement) => ({
          width: window.innerWidth,
          height: window.innerWidth / getLogoAspect(activeLogo),
        })

        const expanded = () => ({
          top: -main.getBoundingClientRect().top,
          left: -main.getBoundingClientRect().left,
          width: window.innerWidth,
          height: window.innerHeight,
        })

        const getPanelRect = (progress: number) => {
          const end = expanded()
          const top = gsap.utils.interpolate(metrics.top, end.top, progress)
          const left = gsap.utils.interpolate(metrics.left, end.left, progress)
          const width = gsap.utils.interpolate(
            metrics.width,
            end.width,
            progress
          )
          const height = gsap.utils.interpolate(
            metrics.height,
            end.height,
            progress
          )

          return { top, left, width, height, bottom: top + height }
        }

        const applyFrame = (progress: number) => {
          const activeLogo = getActiveLogo(panel)
          if (!activeLogo) return

          const panelRect = getPanelRect(progress)
          const logoStart = { width: 200, height: 60 }
          const endLogo = logoEnd(activeLogo)

          gsap.set(panel, {
            top: panelRect.top,
            left: panelRect.left,
            width: panelRect.width,
            height: panelRect.height,
          })

          gsap.set(topLeft, { x: -(metrics.left - panelRect.left) })
          gsap.set(bottomLeft, {
            y: Math.max(0, panelRect.bottom - bottomRowTop),
          })
          gsap.set(bottomRight, {
            y: Math.max(0, panelRect.bottom - bottomRowTop),
          })

          panel
            .querySelectorAll<HTMLImageElement>("[data-hero-aec-logo]")
            .forEach((img) => {
              const isActive = img === activeLogo
              gsap.set(img, {
                opacity: isActive ? 1 : 0,
                width: isActive
                  ? gsap.utils.interpolate(
                      logoStart.width,
                      endLogo.width,
                      progress
                    )
                  : logoStart.width,
                height: isActive
                  ? gsap.utils.interpolate(
                      logoStart.height,
                      endLogo.height,
                      progress
                    )
                  : logoStart.height,
              })
            })
        }

        gsap.set(panel, { position: "absolute" })
        applyHeroFrame = applyFrame
        applyFrame(0)

        const headerHeight =
          document.querySelector("header")?.offsetHeight ?? 50

        scrollTriggerInstance = ScrollTrigger.create({
          trigger: main,
          start: `top ${headerHeight}px`,
          end: "+=100%",
          pin: true,
          scrub: true,
          anticipatePin: 1,
          onUpdate: (self) => {
            heroExpandProgress = self.progress
            applyFrame(self.progress)
          },
          onLeave: () => {
            gsap.set(panel, { top: 0, left: 0, width: "100%", height: "100%" })
            heroExpandProgress = 1
            applyFrame(1)
          },
          onLeaveBack: () => {
            heroExpandProgress = 0
            applyFrame(0)
          },
        })
      }, main)
    }

    const logo = getActiveLogo(panel)
    if (logo && logo.complete && logo.naturalWidth > 0) {
      run()
    } else {
      logo?.addEventListener("load", run, { once: true })
    }
  }

  let initTimeout: ReturnType<typeof setTimeout> | undefined

  function scheduleInit() {
    clearTimeout(initTimeout)
    stopCycle()
    applyHeroFrame = undefined

    const main = document.querySelector<HTMLElement>("[data-hero-main]")
    heroSlides = main?.dataset.heroSlides
      ? JSON.parse(main.dataset.heroSlides)
      : []
    heroCycleSeconds = Number(main?.dataset.heroCycleSeconds ?? 6)
    activeSlide = 0
    heroExpandProgress = 0

    initTimeout = setTimeout(() => {
      updateVerticalSections(activeSlide)
      initHeroCycle()
      initHeroAecExpand()
    }, 0)
  }

  document.addEventListener("astro:page-load", scheduleInit)
  scheduleInit()
</script>
