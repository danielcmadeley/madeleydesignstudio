---
const verticals = [
  { id: "aec", label: "AEC" },
  { id: "marketing", label: "Marketing" },
  { id: "software", label: "Software" },
]

const uniqueSectionLabels = ["One", "Two", "Three"]
const sharedSectionLabels = ["One", "Two", "Three"]
---

<div data-page-sections>
  {
    verticals.map((vertical, slideIndex) =>
      uniqueSectionLabels.map((sectionLabel, sectionIndex) => (
        <section
          data-vertical-section
          data-slide={slideIndex}
          class:list={[
            "min-h-svh flex items-end border-t border-[#BA0000] px-8 py-16 md:px-12 md:py-20",
            slideIndex === 0 ? "bg-[#FDE9C1]" : slideIndex === 1 ? "bg-[#F8EACD]" : "bg-[#fff5e1]",
            slideIndex !== 0 && "hidden",
          ]}
        >
          <div>
            <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#BA0000]">
              {vertical.label}
            </p>
            <h2
              class="font-heading max-w-3xl text-[clamp(1.75rem,3vw,2.75rem)] leading-tight font-bold tracking-tight text-[#2a2a2a]"
            >
              Unique section {sectionLabel}
            </h2>
            <p class="mt-4 max-w-xl text-lg text-[#2a2a2a]/70">
              Placeholder content for {vertical.label.toLowerCase()} section {sectionIndex + 1}.
            </p>
          </div>
        </section>
      )),
    )
  }

  {
    sharedSectionLabels.map((sectionLabel, index) => (
      <section
        data-shared-section
        class:list={[
          "min-h-svh flex items-end border-t border-[#BA0000] px-8 py-16 md:px-12 md:py-20",
          index % 2 === 0 ? "bg-[#F8EACD]" : "bg-[#FDE9C1]",
        ]}
      >
        <div>
          <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#BA0000]">
            Shared
          </p>
          <h2
            class="font-heading max-w-3xl text-[clamp(1.75rem,3vw,2.75rem)] leading-tight font-bold tracking-tight text-[#2a2a2a]"
          >
            Shared section {sectionLabel}
          </h2>
          <p class="mt-4 max-w-xl text-lg text-[#2a2a2a]/70">
            Placeholder content shared across all verticals.
          </p>
        </div>
      </section>
    ))
  }

  <footer
    data-page-footer
    class="min-h-svh flex items-end border-t border-[#BA0000] bg-[#BA0000] px-8 py-16 md:px-12 md:py-20"
  >
    <div>
      <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#FDE9C1]">
        Footer
      </p>
      <h2
        class="font-heading max-w-3xl text-[clamp(1.75rem,3vw,2.75rem)] leading-tight font-bold tracking-tight text-white"
      >
        Shared footer
      </h2>
      <p class="mt-4 max-w-xl text-lg text-white/80">
        Placeholder footer content.
      </p>
    </div>
  </footer>
</div>
