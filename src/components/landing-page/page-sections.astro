---
import ServicesSection from "@/components/landing-page/services-section.astro"
import type {
  PageSection,
  ServiceContent,
  VerticalSectionView,
} from "@/lib/sanity/types"

interface Props {
  verticalSections: VerticalSectionView[]
  services: ServiceContent[]
  footer: PageSection
}

const { verticalSections, services, footer } = Astro.props
---

<div data-page-sections>
  {
    verticalSections.map((section) => (
      <section
        data-vertical-section
        data-slide={section.slideIndex}
        style={{ backgroundColor: section.backgroundColor }}
        class:list={[
          "min-h-svh flex items-end border-t border-[#BA0000] px-8 py-16 md:px-12 md:py-20",
          section.slideIndex !== 0 && "hidden",
        ]}
      >
        <div>
          <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#BA0000]">
            {section.eyebrow}
          </p>
          <h2
            class="font-heading max-w-3xl text-[clamp(1.75rem,3vw,2.75rem)] leading-tight font-bold tracking-tight text-[#2a2a2a]"
          >
            {section.heading}
          </h2>
          <p class="mt-4 max-w-xl text-lg text-[#2a2a2a]/70">
            {section.body}
          </p>
        </div>
      </section>
    ))
  }

  <ServicesSection services={services} />

  <footer
    data-page-footer
    style={{ backgroundColor: footer.backgroundColor }}
    class="min-h-svh flex items-end border-t border-[#BA0000] px-8 py-16 md:px-12 md:py-20"
  >
    <div>
      <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#FDE9C1]">
        {footer.eyebrow}
      </p>
      <h2
        class="font-heading max-w-3xl text-[clamp(1.75rem,3vw,2.75rem)] leading-tight font-bold tracking-tight text-white"
      >
        {footer.heading}
      </h2>
      <p class="mt-4 max-w-xl text-lg text-white/80">
        {footer.body}
      </p>
    </div>
  </footer>
</div>
