---
import type { ServiceContent } from "@/lib/sanity/types"

interface Props {
  services: ServiceContent[]
}

const { services } = Astro.props

const CIRCUIT_LINE_COLOR = "#F6DE8D"
const CARD_SURROUND_COLOR = "#F2BE9E"
---

<section
  data-services-section
  class="flex flex-col gap-32 bg-[#FDE9C1] py-24 md:gap-56 md:py-40"
>
  {
    services.map((service, index) => {
      const anchoredRight = index % 2 === 0

      return (
        <article
          class:list={[
            "w-5/6 border-y border-[#BA0000]",
            anchoredRight ? "ml-auto border-l" : "mr-auto border-r",
          ]}
          style={{ backgroundColor: CARD_SURROUND_COLOR }}
        >
          <div class="p-2 md:p-3">
            <div
              class="relative aspect-2/1"
              style={{
                backgroundColor: service.panelColor,
                backgroundImage:
                  "linear-gradient(rgba(255,255,255,0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.12) 1px, transparent 1px)",
                backgroundSize: "48px 48px",
              }}
            >
              <svg
                class="absolute inset-0 h-full w-full"
                viewBox="0 0 200 100"
                preserveAspectRatio="none"
                fill="none"
                aria-hidden="true"
              >
                <rect
                  x="50"
                  y="18"
                  width="100"
                  height="63"
                  fill={service.panelInnerColor}
                />
                <g stroke={CIRCUIT_LINE_COLOR} stroke-width="1.25">
                  <path d="M 10 20 H 25" vector-effect="non-scaling-stroke" />
                  <path d="M 10 16.5 V 23.5" vector-effect="non-scaling-stroke" />
                  <path
                    d="M 30 31 V 86.5 H 100"
                    vector-effect="non-scaling-stroke"
                  />
                  <path
                    d="M 110 86.5 H 142"
                    vector-effect="non-scaling-stroke"
                  />
                  <path d="M 142 83 V 90" vector-effect="non-scaling-stroke" />
                  <path
                    d="M 197 20 H 179 V 49"
                    vector-effect="non-scaling-stroke"
                  />
                  <path d="M 174 54 H 150" vector-effect="non-scaling-stroke" />
                </g>
                <g fill={service.panelBlockColor} fill-opacity="0.9">
                  <rect x="25" y="9" width="22" height="22" />
                  <rect x="151" y="8" width="11" height="11" />
                  <rect x="174" y="49" width="10" height="10" />
                  <rect x="14" y="81" width="11" height="11" />
                  <rect x="100" y="83" width="10" height="10" />
                </g>
              </svg>
            </div>
          </div>
          <div
            class:list={[
              "border-t border-[#BA0000] px-4 py-2.5 text-xs text-[#2a2a2a] md:px-6 md:text-sm",
              anchoredRight ? "text-left" : "text-right",
            ]}
          >
            {service.description}
          </div>
          <h3
            class:list={[
              "font-heading border-t border-[#BA0000] px-4 py-3 text-lg font-bold tracking-tight text-[#2a2a2a] md:px-6 md:py-4 md:text-2xl",
              anchoredRight ? "text-left" : "text-right",
            ]}
          >
            {service.title}
          </h3>
        </article>
      )
    })
  }
</section>
