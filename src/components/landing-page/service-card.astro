---
import type { ServiceContent } from "@/lib/sanity/types"

interface Props {
  service: ServiceContent
  anchoredRight: boolean
}

const { service, anchoredRight } = Astro.props

const CIRCUIT_LINE_COLOR = "#F6DE8D"
const CARD_SURROUND_COLOR = "#F2BE9E"

// Panel viewBox is 200x100 (2:1, matching the aspect ratio), gridded 16x8
const CELL = 12.5
const gridColumns = Array.from({ length: 15 }, (_, i) => (i + 1) * CELL)
const gridRows = Array.from({ length: 7 }, (_, i) => (i + 1) * CELL)

const DOT_SIZE = 0.9
const lineDots: [number, number][] = [
  [25, 25],
  [18.75, 75],
  [25, 81.25],
  [100, 81.25],
  [181.25, 50],
  [150, 62.5],
  [175, 62.5],
]
---

<article
  class:list={[
    "w-5/6 border-y border-[#353535]",
    anchoredRight ? "ml-auto border-l" : "mr-auto border-r",
  ]}
  style={{ backgroundColor: CARD_SURROUND_COLOR }}
>
  <div class="p-2 md:p-3">
    <div
      class="relative aspect-2/1 overflow-hidden"
      style={{ backgroundColor: service.panelColor }}
    >
      <div
        class="absolute inset-0 opacity-10"
        style={{
          backgroundImage:
            "repeating-radial-gradient(circle at 30% 25%, rgba(255,255,255,0.8) 0 0.5px, transparent 0.5px 3px), repeating-radial-gradient(circle at 75% 80%, rgba(20,10,15,0.7) 0 0.5px, transparent 0.5px 3.5px)",
        }}
      >
      </div>
      <div
        class="absolute inset-0 opacity-30"
        style={{
          background:
            "radial-gradient(ellipse 70% 60% at 50% 40%, #4A3F4C, transparent 75%)",
        }}
      >
      </div>
      <svg
        class="absolute inset-0 h-full w-full"
        viewBox="0 0 200 100"
        preserveAspectRatio="none"
        fill="none"
        aria-hidden="true"
      >
        <g
          stroke={CIRCUIT_LINE_COLOR}
          stroke-opacity="0.3"
          stroke-width="1"
        >
          {
            gridColumns.map((x) => (
              <path d={`M ${x} 0 V 100`} vector-effect="non-scaling-stroke" />
            ))
          }
          {
            gridRows.map((y) => (
              <path d={`M 0 ${y} H 200`} vector-effect="non-scaling-stroke" />
            ))
          }
        </g>
        <rect
          x="150"
          y="12.5"
          width="12.5"
          height="12.5"
          fill="#FFFFFF"
          fill-opacity="0.15"></rect>
        <rect
          x="100"
          y="75"
          width="25"
          height="12.5"
          fill="#FFFFFF"
          fill-opacity="0.18"></rect>
        <rect
          x="175"
          y="50"
          width="12.5"
          height="25"
          fill="#FFFFFF"
          fill-opacity="0.15"></rect>
        <rect
          x="50"
          y="12.5"
          width="100"
          height="62.5"
          fill={service.panelInnerColor}></rect>
        <g fill={service.panelBlockColor}>
          <rect x="25" y="12.5" width="25" height="25"></rect>
          <rect x="12.5" y="75" width="12.5" height="12.5"></rect>
        </g>
        <g stroke={CIRCUIT_LINE_COLOR} stroke-width="1.25">
          <path
            d="M 25 25 H 9.5 V 39 H 18.75 V 75"
            vector-effect="non-scaling-stroke"></path>
          <path d="M 25 81.25 H 100" vector-effect="non-scaling-stroke"></path>
          <path d="M 200 23.5 H 181.25 V 50" vector-effect="non-scaling-stroke"
          ></path>
          <path d="M 150 62.5 H 175" vector-effect="non-scaling-stroke"></path>
        </g>
        <g fill={CIRCUIT_LINE_COLOR}>
          {
            lineDots.map(([cx, cy]) => (
              <rect
                x={cx - DOT_SIZE / 2}
                y={cy - DOT_SIZE / 2}
                width={DOT_SIZE}
                height={DOT_SIZE}
              />
            ))
          }
        </g>
      </svg>
    </div>
  </div>
  <div
    class:list={[
      "border-t border-[#353535] px-4 py-2.5 text-xs text-[#353535] md:px-6 md:text-sm",
      anchoredRight ? "text-left" : "text-right",
    ]}
  >
    {service.description}
  </div>
  <h3
    class:list={[
      "font-heading border-t border-[#353535] px-4 py-3 text-lg font-bold tracking-tight text-[#353535] md:px-6 md:py-4 md:text-2xl",
      anchoredRight ? "text-left" : "text-right",
    ]}
  >
    {service.title}
  </h3>
</article>
