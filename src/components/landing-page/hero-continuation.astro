---
interface HeroSlide {
  id: string
  flippedImage: string
  continuationImageAlt?: string
}

interface Props {
  slides: HeroSlide[]
  tagline: string
}

const { slides, tagline } = Astro.props
---

<section class="relative bg-[#FDE9C1]">
  <div class="grid">
    {
      slides.map((slide, index) => (
        <img
          data-hero-continuation
          data-slide={index}
          src={slide.flippedImage}
          alt={slide.continuationImageAlt ?? ""}
          aria-hidden="true"
          class:list={[
            "col-start-1 row-start-1 block h-auto w-full",
            index === 0 ? "opacity-100" : "opacity-0",
          ]}
        />
      ))
    }
  </div>
  <div class="min-h-svh px-8 py-24 md:px-12">
    <p
      class="font-heading max-w-3xl text-[clamp(1.5rem,3vw,2.5rem)] leading-tight font-bold tracking-tight text-[#2a2a2a]"
    >
      {tagline}
    </p>
  </div>
</section>
