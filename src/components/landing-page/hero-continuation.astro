---
import type { HeroSlideView } from "@/lib/sanity/types"

interface Props {
  slides: Pick<
    HeroSlideView,
    | "id"
    | "flippedImage"
    | "flippedImageSrcSet"
    | "flippedImageWidth"
    | "flippedImageHeight"
    | "continuationImageAlt"
  >[]
  tagline: string
}

const { slides, tagline } = Astro.props
---

<section class="relative bg-sand">
  <div class="grid">
    {
      slides.map((slide, index) => (
        <img
          data-hero-continuation
          data-slide={index}
          src={slide.flippedImage}
          srcset={slide.flippedImageSrcSet}
          sizes="100vw"
          width={slide.flippedImageWidth}
          height={slide.flippedImageHeight}
          alt={slide.continuationImageAlt ?? ""}
          loading="lazy"
          decoding="async"
          aria-hidden="true"
          class:list={[
            "col-start-1 row-start-1 block h-auto w-full",
            index === 0 ? "opacity-100" : "opacity-0",
          ]}
        />
      ))
    }
  </div>
  <div class="min-h-svh px-8 py-24 md:px-12">
    <p
      class="max-w-3xl font-heading text-[clamp(1.5rem,3vw,2.5rem)] leading-tight font-bold tracking-tight text-ink"
    >
      {tagline}
    </p>
  </div>
</section>
