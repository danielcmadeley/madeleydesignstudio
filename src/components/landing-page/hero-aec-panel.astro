---
import type { HeroSlideView } from "@/lib/sanity/types"

interface Props {
  slides: Pick<HeroSlideView, "id" | "subtext" | "image" | "logoImageAlt">[]
}

const { slides } = Astro.props
---

<div
  data-hero-aec-cell
  class="relative col-span-1 col-start-3 row-start-1 min-h-0"
>
  <section
    data-hero-aec
    class="absolute inset-0 border-l border-brand-red bg-sand px-6 py-10 will-change-[top,left,width,height] md:px-8 md:py-14"
  >
    <div class="grid max-w-[80%]">
      {
        slides.map((slide, index) => (
          <p
            data-hero-subtext
            data-slide={index}
            class:list={[
              "col-start-1 row-start-1 text-3xl leading-snug font-medium text-ink-deep",
              index === 0 ? "opacity-100" : "opacity-0",
            ]}
          >
            {slide.subtext}
          </p>
        ))
      }
    </div>
    {
      slides.map((slide, index) => (
        <img
          data-hero-aec-logo
          data-slide={index}
          src={slide.image}
          alt={slide.logoImageAlt ?? ""}
          class:list={[
            "absolute right-0 bottom-0 h-[60px] w-[200px] object-contain object-bottom-right will-change-[width,height]",
            index === 0 ? "opacity-100" : "opacity-0",
          ]}
        />
      ))
    }
  </section>
</div>
