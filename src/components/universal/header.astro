---
import type { SiteSettingsContent } from "@/lib/sanity/types"

interface Props {
  siteSettings: SiteSettingsContent
}

const { siteSettings } = Astro.props
const { headerCta } = siteSettings
---

<header
  class="fixed top-0 right-0 left-0 z-50 flex h-[50px] w-full items-center justify-between border-b border-[#BA0000] bg-[#F8EACD]"
>
  <a
    href="/"
    class="font-heading pl-6 text-sm lowercase text-[#BA0000] no-underline"
  >
    {siteSettings.siteName}
  </a>
  <a
    href={headerCta.url}
    target={headerCta.openInNewTab ? "_blank" : undefined}
    rel={headerCta.openInNewTab ? "noreferrer noopener" : undefined}
    class="flex h-full items-center bg-[#BA0000] px-6 text-sm lowercase text-white no-underline"
  >
    {headerCta.label}
  </a>
</header>
